# Voyagers Tribute - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/voyagers_db

# ============================================
# AUTHENTICATION
# ============================================
# JWT Secret key - use a strong random string in production
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-key-change-in-production-min-32-characters

# ============================================
# AI/ML SERVICES
# ============================================
# Google Gemini API Key - get from https://ai.google.dev
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ============================================
# FRONTEND
# ============================================
# URL where frontend is hosted (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================
# WEBSOCKET
# ============================================
# WebSocket server URL for real-time updates
WS_URL=ws://localhost:3001

# ============================================
# RATE LIMITING
# ============================================
# Time window for rate limiting in milliseconds (15 minutes = 900000)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=500

# ============================================
# JWT CONFIGURATION
# ============================================
# JWT token expiry time
JWT_EXPIRY=24h

# ============================================
# DEVELOPMENT ONLY
# ============================================
# Set to true to enable debug logging
DEBUG=false

# Seed database on startup (development only)
AUTO_SEED=false
